{
  "name": "aidlc-studio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "s2.5:capture": "bun run scripts/s2.5-capture.ts",
    "s3:capture": "bun run scripts/s3-capture.ts",
    "s3:capture:v004": "bun run scripts/s3-v004-capture.ts",
    "s3:capture:v005": "bun run scripts/s3-v005-capture.ts",
    "s3:capture:v006": "bun run scripts/s3-v006-capture.ts",
    "test": "bun test src tests/integration",
    "test:live": "bun test tests/e2e-live",
    "test:domain": "bun test src/domain",
    "test:int": "bun test tests/integration",
    "typecheck": "tsc --noEmit",
    "serve": "bun run src/main.ts",
    "serve:live": "AIDLC_ORCHESTRATOR=live bun run src/main.ts",
    "verify": "lsof -ti:8787 | xargs -I{} kill {} 2>/dev/null; cd web && bun run build && cd .. && AIDLC_ORCHESTRATOR=live bun run src/main.ts",
    "verify:watch": "lsof -ti:8787 | xargs -I{} kill {} 2>/dev/null; trap 'kill 0' EXIT; AIDLC_ORCHESTRATOR=live bun --watch run src/main.ts & cd web && bun run dev",
    "verify:test": "bun run scripts/verify-test.ts",
    "verify:visual": "bun run scripts/s8-visual-eval.ts",
    "verify:shot": "bun run scripts/ui-shot.ts",
    "ledger:migrate": "bun run scripts/migrate-root-ledger.ts",
    "ledger:check": "bun run scripts/migrate-root-ledger.ts --check",
    "reconcile": "bun run scripts/reconcile-check.ts",
    "probe:rules": "bun run scripts/probe-binding-rules.ts",
    "verify:v005": "bun run scripts/verify-v005.ts",
    "live:run": "bun run scripts/live-run-s1.ts",
    "live:check": "bun run scripts/check-live-dossier.ts",
    "gate:setup": "bun run scripts/setup-gate-demo.ts",
    "gate:demo": "bun run scripts/live-gate-demo.ts",
    "evidence:show": "bun run scripts/evidence-show.ts",
    "evidence:check": "bun run scripts/evidence-check.ts",
    "evidence:gen": "bun run scripts/generate-evidence.ts",
    "seed:cycle": "bun run scripts/seed-cycle.ts",
    "seed:suite": "bun run scripts/seed-suite.ts",
    "seed:capture": "bun run scripts/seed-suite-capture.ts",
    "clear:test": "bun run scripts/verify-test.ts --reset",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report tests/e2e/.report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.14",
    "playwright": "^1.49.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "hono": "^4.12.23"
  }
}
